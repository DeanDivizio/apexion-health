generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GymExerciseType {
  strength
  cardio
}

enum GymRepMode {
  bilateral
  dualUnilateral
}

model GymWorkoutSession {
  id                String               @id @default(uuid())
  userId            String
  dateStr           String
  startTimeStr      String
  endTimeStr        String
  sessionName       String?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  exercises         GymWorkoutExercise[]
  biometricWorkouts BiometricWorkout[]

  @@index([userId, dateStr])
}

model GymWorkoutExercise {
  id                   String                        @id @default(uuid())
  sessionId            String
  session              GymWorkoutSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order                Int
  type                 GymExerciseType
  exerciseKey          String
  presetName           String?
  notes                String?
  durationMinutes      Float?
  distance             Float?
  distanceUnit         String?
  supersetGroupId      String?
  supersetTemplateId   String?
  supersetTemplate     GymSupersetTemplate?          @relation(fields: [supersetTemplateId], references: [id], onDelete: SetNull)
  strengthSets         GymStrengthSet[]
  variations           GymWorkoutExerciseVariation[]

  @@index([sessionId, order])
  @@index([exerciseKey])
  @@index([supersetGroupId])
}

model GymStrengthSet {
  id             String             @id @default(uuid())
  exerciseId     String
  exercise       GymWorkoutExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  order          Int
  weight         Float
  repsBilateral  Int?
  repsLeft       Int?
  repsRight      Int?
  effort         Int?
  durationSeconds Int?
  failureMode    String?
  name           String?
  notes          String?

  @@index([exerciseId, order])
}

model GymVariationTemplate {
  id               String                         @id
  label            String
  options          GymVariationOption[]
  exerciseSupports GymExerciseVariationSupport[]
  optionOverrides  GymExerciseVariationOptionLabelOverride[]
  effects          GymExerciseVariationEffect[]
  workoutVariations GymWorkoutExerciseVariation[]
}

model GymVariationOption {
  id         String               @id @default(uuid())
  templateId String
  template   GymVariationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String
  label      String
  order      Int?

  @@unique([templateId, key])
}

model GymCustomExercise {
  id               String                                @id @default(uuid())
  userId           String
  key              String
  name             String
  category         String
  repMode          GymRepMode
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt
  archivedAt       DateTime?
  presetId         String?
  movementPattern  String?
  bodyRegion       String?
  movementPlane    String?
  targets          GymCustomExerciseTarget[]
  variationSupports GymExerciseVariationSupport[]
  optionOverrides  GymExerciseVariationOptionLabelOverride[]
  effects          GymExerciseVariationEffect[]
  canonRequests    GymCanonRequest[]

  @@unique([userId, key])
  @@index([userId])
}

model GymCanonRequest {
  id                String            @id @default(uuid())
  userId            String
  customExerciseId  String
  customExercise    GymCustomExercise @relation(fields: [customExerciseId], references: [id], onDelete: Cascade)
  status            String            @default("new")
  userNote          String?
  adminNote         String?
  snapshotPayload   Json
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

model GymCustomExerciseTarget {
  id         String             @id @default(uuid())
  exerciseId String
  exercise   GymCustomExercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle     String
  weight     Float

  @@unique([exerciseId, muscle])
}

model GymExerciseVariationSupport {
  id               String               @id @default(uuid())
  exerciseId       String
  exercise         GymCustomExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  templateId       String
  template         GymVariationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  labelOverride    String?
  defaultOptionKey String?

  @@unique([exerciseId, templateId])
}

model GymExerciseVariationOptionLabelOverride {
  id         String               @id @default(uuid())
  exerciseId String
  exercise   GymCustomExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  templateId String
  template   GymVariationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  optionKey  String
  labelOverride String

  @@unique([exerciseId, templateId, optionKey])
}

model GymExerciseVariationEffect {
  id         String               @id @default(uuid())
  exerciseId String
  exercise   GymCustomExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  templateId String
  template   GymVariationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  optionKey  String
  multipliers Json?
  deltas     Json?

  @@unique([exerciseId, templateId, optionKey])
}

model GymWorkoutExerciseVariation {
  id         String               @id @default(uuid())
  exerciseId String
  exercise   GymWorkoutExercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  templateId String
  template   GymVariationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  optionKey  String

  @@unique([exerciseId, templateId])
}

model GymUserExerciseStat {
  id             String   @id @default(uuid())
  userId         String
  exerciseKey    String
  presetName     String   @default("")
  prDateStr      String?
  prWeight       Float?
  prRepsBilateral Int?
  prRepsLeft     Int?
  prRepsRight    Int?
  prTotalVolume  Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, exerciseKey, presetName])
  @@index([userId])
}

model GymUserPreferences {
  id              String   @id @default(uuid())
  userId          String   @unique
  weightUnit      String   @default("lbs")
  repInputStyle   String   @default("dropdown")
  carryOverWeight Boolean  @default(true)
  carryOverReps   Boolean  @default(false)
  showFailureMode Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GymUserExerciseDefault {
  id          String @id @default(cuid())
  userId      String
  exerciseKey String
  templateId  String
  optionKey   String

  @@unique([userId, exerciseKey, templateId])
  @@index([userId, exerciseKey])
}

model GymExerciseVariationPreset {
  id          String   @id @default(uuid())
  userId      String
  exerciseKey String
  name        String
  variations  Json
  createdAt   DateTime @default(now())

  @@unique([userId, exerciseKey, name])
  @@index([userId])
}

model GymSupersetTemplate {
  id            String               @id @default(uuid())
  userId        String
  exerciseAKey  String
  exerciseBKey  String
  createdAt     DateTime             @default(now())

  workoutExercises GymWorkoutExercise[]

  @@unique([userId, exerciseAKey, exerciseBKey])
  @@index([userId])
}

// ─── Substance / Medication Logging ──────────────────────────────────────────

model Substance {
  id                String  @id @default(uuid())
  ownerUserId       String?
  key               String  @unique
  displayName       String
  isCompound        Boolean @default(false)
  defaultDoseUnit   String? @default("mg")
  selfIngredientKey String?
  brand             String?
  notes             String?
  active            Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  methodLinks SubstanceMethodLink[]
  variants    SubstanceVariant[]
  ingredients SubstanceIngredient[]
  logItems    SubstanceLogItem[]
  presetItems SubstancePresetItem[]

  @@index([ownerUserId])
  @@index([selfIngredientKey])
}

model SubstanceDeliveryMethod {
  id        String  @id @default(uuid())
  key       String  @unique
  label     String
  active    Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  methodLinks SubstanceMethodLink[]
  variants    SubstanceVariant[]
  logItems    SubstanceLogItem[]
  presetItems SubstancePresetItem[]
}

model SubstanceMethodLink {
  substanceId      String
  substance        Substance              @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  deliveryMethodId String
  deliveryMethod   SubstanceDeliveryMethod @relation(fields: [deliveryMethodId], references: [id], onDelete: Cascade)

  @@id([substanceId, deliveryMethodId])
}

model SubstanceVariant {
  id               String                   @id @default(uuid())
  substanceId      String
  substance        Substance                @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  deliveryMethodId String?
  deliveryMethod   SubstanceDeliveryMethod? @relation(fields: [deliveryMethodId], references: [id], onDelete: SetNull)
  key              String
  label            String
  active           Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  logItems    SubstanceLogItem[]
  presetItems SubstancePresetItem[]

  @@unique([substanceId, key])
  @@index([substanceId])
  @@index([deliveryMethodId])
}

model SubstanceIngredient {
  id               String    @id @default(uuid())
  substanceId      String
  substance        Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  ingredientKey    String
  ingredientName   String
  amountPerServing Float
  unit             String    @default("mg")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  logItemIngredients SubstanceLogItemIngredient[]

  @@unique([substanceId, ingredientKey])
  @@index([substanceId])
  @@index([ingredientKey])
}

model SubstancePreset {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       SubstancePresetItem[]
  logSessions SubstanceLogSession[]

  @@index([userId, updatedAt])
}

model SubstancePresetItem {
  id               String                   @id @default(uuid())
  presetId         String
  preset           SubstancePreset          @relation(fields: [presetId], references: [id], onDelete: Cascade)
  substanceId      String
  substance        Substance                @relation(fields: [substanceId], references: [id], onDelete: Restrict)
  snapshotName     String
  doseValue        Float?
  doseUnit         String?
  compoundServings Float?
  deliveryMethodId String?
  deliveryMethod   SubstanceDeliveryMethod? @relation(fields: [deliveryMethodId], references: [id], onDelete: SetNull)
  variantId        String?
  variant          SubstanceVariant?        @relation(fields: [variantId], references: [id], onDelete: SetNull)
  injectionDepth   String?
  sortOrder        Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([presetId, sortOrder])
  @@index([substanceId])
  @@index([deliveryMethodId])
  @@index([variantId])
}

model SubstanceLogSession {
  id       String   @id @default(uuid())
  userId   String
  loggedAt DateTime
  presetId String?
  preset   SubstancePreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SubstanceLogItem[]

  @@index([userId, loggedAt])
  @@index([presetId])
}

model SubstanceLogItem {
  id               String                       @id @default(uuid())
  sessionId        String
  session          SubstanceLogSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String
  substanceId      String
  substance        Substance                    @relation(fields: [substanceId], references: [id], onDelete: Restrict)
  snapshotName     String
  doseValue        Float?
  doseUnit         String?
  compoundServings Float?
  deliveryMethodId String?
  deliveryMethod   SubstanceDeliveryMethod?     @relation(fields: [deliveryMethodId], references: [id], onDelete: SetNull)
  variantId        String?
  variant          SubstanceVariant?            @relation(fields: [variantId], references: [id], onDelete: SetNull)
  injectionDepth   String?
  sortOrder        Int                          @default(0)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  ingredients SubstanceLogItemIngredient[]

  @@index([sessionId, sortOrder])
  @@index([userId, createdAt])
  @@index([substanceId, createdAt])
  @@index([deliveryMethodId])
  @@index([variantId])
}

model SubstanceLogItemIngredient {
  id                     String              @id @default(uuid())
  logItemId              String
  logItem                SubstanceLogItem    @relation(fields: [logItemId], references: [id], onDelete: Cascade)
  sourceIngredientId     String?
  sourceIngredient       SubstanceIngredient? @relation(fields: [sourceIngredientId], references: [id], onDelete: SetNull)
  ingredientKey          String
  ingredientName         String
  amountTotal            Float
  unit                   String              @default("mg")
  sourceAmountPerServing Float
  sourceServings         Float
  createdAt              DateTime            @default(now())

  @@index([logItemId])
  @@index([ingredientKey, amountTotal])
  @@index([sourceIngredientId])
}

// ─── Provider Connections (extensible for any OAuth provider) ────────────────

enum ProviderConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

model ProviderConnection {
  id             String                   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String?
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         String[]
  status         ProviderConnectionStatus @default(ACTIVE)
  lastSyncAt     DateTime?
  syncCursor     Json?
  errorMessage   String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  whoopCycles    WhoopCycle[]
  whoopSleeps    WhoopSleep[]
  whoopRecoveries WhoopRecovery[]
  whoopWorkouts  WhoopWorkout[]

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, status])
  @@index([providerUserId, provider])
}

// ─── Whoop Raw Data (mirrors Whoop API shapes) ──────────────────────────────

model WhoopCycle {
  id               String             @id @default(uuid())
  connectionId     String
  connection       ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  whoopCycleId     Int                @unique
  whoopUserId      Int
  start            DateTime
  end              DateTime?
  timezoneOffset   String
  scoreState       String
  strain           Float?
  kilojoule        Float?
  averageHeartRate Int?
  maxHeartRate     Int?
  rawJson          Json
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([connectionId])
  @@index([whoopUserId, start])
}

model WhoopSleep {
  id                          String             @id @default(uuid())
  connectionId                String
  connection                  ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  whoopSleepId                String             @unique
  whoopCycleId                Int
  whoopUserId                 Int
  start                       DateTime
  end                         DateTime
  timezoneOffset              String
  nap                         Boolean
  scoreState                  String
  totalInBedTimeMilli         Int?
  totalAwakeTimeMilli         Int?
  totalNoDataTimeMilli        Int?
  totalLightSleepTimeMilli    Int?
  totalSlowWaveSleepTimeMilli Int?
  totalRemSleepTimeMilli      Int?
  sleepCycleCount             Int?
  disturbanceCount            Int?
  sleepNeededBaselineMilli    Int?
  needFromSleepDebtMilli      Int?
  needFromRecentStrainMilli   Int?
  needFromRecentNapMilli      Int?
  respiratoryRate             Float?
  sleepPerformancePct         Float?
  sleepConsistencyPct         Float?
  sleepEfficiencyPct          Float?
  rawJson                     Json
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  @@index([connectionId])
  @@index([whoopUserId, start])
  @@index([whoopCycleId])
}

model WhoopRecovery {
  id               String             @id @default(uuid())
  connectionId     String
  connection       ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  whoopCycleId     Int                @unique
  whoopSleepId     String
  whoopUserId      Int
  scoreState       String
  userCalibrating  Boolean?
  recoveryScore    Float?
  restingHeartRate Float?
  hrvRmssdMilli    Float?
  spo2Percentage   Float?
  skinTempCelsius  Float?
  rawJson          Json
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([connectionId])
  @@index([whoopUserId])
}

model WhoopWorkout {
  id                  String             @id @default(uuid())
  connectionId        String
  connection          ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  whoopWorkoutId      String             @unique
  whoopUserId         Int
  start               DateTime
  end                 DateTime
  timezoneOffset      String
  sportName           String
  sportId             Int?
  scoreState          String
  strain              Float?
  averageHeartRate    Int?
  maxHeartRate        Int?
  kilojoule           Float?
  percentRecorded     Float?
  distanceMeter       Float?
  altitudeGainMeter   Float?
  altitudeChangeMeter Float?
  zoneZeroMilli       Int?
  zoneOneMilli        Int?
  zoneTwoMilli        Int?
  zoneThreeMilli      Int?
  zoneFourMilli       Int?
  zoneFiveMilli       Int?
  rawJson             Json
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([connectionId])
  @@index([whoopUserId, start])
}

// ─── Canonical Biometric Tables (provider-agnostic, day-indexed) ─────────────

model BiometricSleep {
  id                       String   @id @default(uuid())
  userId                   String
  dateStr                  String
  provider                 String
  providerSleepId          String?
  nap                      Boolean  @default(false)
  start                    DateTime
  end                      DateTime
  totalInBedTimeMilli      Int?
  totalAwakeTimeMilli      Int?
  totalLightSleepTimeMilli Int?
  totalDeepSleepTimeMilli  Int?
  totalRemSleepTimeMilli   Int?
  sleepCycleCount          Int?
  disturbanceCount         Int?
  sleepNeededMilli         Int?
  respiratoryRate          Float?
  sleepPerformancePct      Float?
  sleepConsistencyPct      Float?
  sleepEfficiencyPct       Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([userId, providerSleepId])
  @@index([userId, dateStr])
}

model BiometricRecovery {
  id                  String   @id @default(uuid())
  userId              String
  dateStr             String
  provider            String
  providerRecoveryRef String?
  recoveryScore       Float?
  restingHeartRate    Float?
  hrvRmssdMilli       Float?
  spo2Percentage      Float?
  skinTempCelsius     Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, dateStr, provider])
  @@index([userId, dateStr])
}

model BiometricWorkout {
  id                String             @id @default(uuid())
  userId            String
  dateStr           String
  provider          String
  providerWorkoutId String?
  sportName         String?
  start             DateTime
  end               DateTime
  strain            Float?
  averageHeartRate  Int?
  maxHeartRate      Int?
  kilojoule         Float?
  distanceMeter     Float?
  zoneZeroMilli     Int?
  zoneOneMilli      Int?
  zoneTwoMilli      Int?
  zoneThreeMilli    Int?
  zoneFourMilli     Int?
  zoneFiveMilli     Int?
  gymSessionId      String?
  gymSession        GymWorkoutSession? @relation(fields: [gymSessionId], references: [id], onDelete: SetNull)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, providerWorkoutId])
  @@index([userId, dateStr])
  @@index([gymSessionId])
}

model BiometricCycleSummary {
  id               String   @id @default(uuid())
  userId           String
  dateStr          String
  provider         String
  providerCycleRef String?
  strain           Float?
  kilojoule        Float?
  averageHeartRate Int?
  maxHeartRate     Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, dateStr, provider])
  @@index([userId, dateStr])
}

model BiometricBodyMeasurement {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  dateStr        String
  heightMeter    Float?
  weightKilogram Float?
  maxHeartRate   Int?
  fetchedAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, provider, dateStr])
  @@index([userId, dateStr])
}

model HydrationLog {
  id              String   @id @default(uuid())
  userId          String
  amountOz        Float
  beverageType    String   @default("water")
  beverageSubtype String?
  caffeineMg      Float    @default(0)
  dateStr         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, dateStr])
}

enum ActivityDimensionKind {
  text
  number
  number_with_unit
  date
  time
  datetime
  scale_1_5
}

model ActivityType {
  id         String   @id @default(uuid())
  userId     String
  name       String
  color      String?
  icon       String?
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  dimensions ActivityDimension[]
  logs       ActivityLog[]

  @@unique([userId, name])
  @@index([userId, archivedAt])
}

model ActivityDimension {
  id             String                @id @default(uuid())
  activityTypeId String
  activityType   ActivityType          @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  key            String
  label          String
  kind           ActivityDimensionKind
  required       Boolean               @default(false)
  sortOrder      Int                   @default(0)
  config         Json?
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  logValues ActivityLogValue[]

  @@unique([activityTypeId, key])
  @@index([activityTypeId, sortOrder])
}

model ActivityLog {
  id                    String   @id @default(uuid())
  userId                String
  activityTypeId        String
  activityType          ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Restrict)
  loggedAt              DateTime
  dateStr               String
  timezoneOffsetMinutes Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  values ActivityLogValue[]

  @@index([userId, dateStr])
  @@index([activityTypeId, loggedAt])
}

model ActivityLogValue {
  id           String                @id @default(uuid())
  logId         String
  log           ActivityLog           @relation(fields: [logId], references: [id], onDelete: Cascade)
  dimensionId   String?
  dimension     ActivityDimension?    @relation(fields: [dimensionId], references: [id], onDelete: SetNull)
  keySnapshot   String
  labelSnapshot String
  kindSnapshot  ActivityDimensionKind
  textValue     String?
  numberValue   Float?
  unitValue     String?
  dateValue     String?
  timeValue     String?
  dateTimeValue DateTime?
  intValue      Int?
  jsonValue     Json?
  createdAt     DateTime              @default(now())

  @@index([logId])
  @@index([dimensionId])
}

model UserHomePreferences {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  showMacroSummary         Boolean  @default(true)
  macroSummarySize         String   @default("large")
  showHydrationSummary     Boolean  @default(true)
  showMicroNutrientSummary Boolean  @default(false)
  showWorkoutSummary       Boolean  @default(true)
  showMedsSummary          Boolean  @default(true)
  showActivitySummary      Boolean  @default(true)
  showActivityCalendar        Boolean  @default(false)
  showActivityCompactSummary  Boolean  @default(true)
  pinnedActivityTypeIds       Json     @default("[]")
  componentOrder           Json     @default("[\"macroSummary\",\"hydrationSummary\",\"workoutSummary\",\"medsSummary\",\"microNutrientSummary\",\"activitySummary\"]")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ─── Nutrition ──────────────────────────────────────────────────────────────

enum NutritionFoodSource {
  foundation
  complex
  retail
  ai_estimate
}

enum NutritionSourceType {
  csv
  xlsx
  pdf
  html_link
  manual_upload
}

enum NutritionFetchMethod {
  direct_download
  manual_upload_only
}

enum NutritionParserPreference {
  deterministic_first
  ocr_allowed
}

enum NutritionIngestionRunStatus {
  queued
  fetching
  fetched
  parsing
  staged
  needs_source
  fetch_failed
  review_required
  publish_ready
  published
  rejected
}

enum NutritionExtractionMethod {
  csv_parser
  xlsx_parser
  pdf_table_parser
  ocr_llm
}

enum NutritionValidationSeverity {
  hard
  soft
  info
}

model NutritionFoundationFood {
  id                 String   @id @default(uuid())
  fdcId              Int      @unique
  name               String
  category           String?
  nutrients          Json
  portions           Json?
  defaultServingSize Float    @default(100)
  defaultServingUnit String   @default("g")
  createdAt          DateTime @default(now())

  @@index([name])
}

model NutritionUserFood {
  id          String   @id @default(uuid())
  userId      String
  name        String
  brand       String?
  nutrients   Json
  servingSize Float
  servingUnit String   @default("g")
  ingredients String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, name])
  @@index([userId, active])
}

model NutritionRetailChain {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  globalItems    NutritionRetailItem[]
  userItems      NutritionRetailUserItem[]
  sources        NutritionRetailChainSource[]
  ingestionRuns  NutritionRetailIngestionRun[]
  stagingItems   NutritionRetailStagingItem[]
  itemVersions   NutritionRetailItemVersion[]
  itemAliases    NutritionRetailItemAlias[]
}

model NutritionRetailItem {
  id          String               @id @default(uuid())
  chainId     String
  chain       NutritionRetailChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  name        String
  normalizedName String?
  category    String?
  nutrients   Json
  servingSize Float?
  servingUnit String?
  sourceType  NutritionSourceType?
  sourceUrl   String?
  lastIngestionRunId String?
  lastIngestionRun NutritionRetailIngestionRun? @relation(fields: [lastIngestionRunId], references: [id], onDelete: SetNull)
  lastArtifactId String?
  lastArtifact NutritionRetailIngestionArtifact? @relation(fields: [lastArtifactId], references: [id], onDelete: SetNull)
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  aliases     NutritionRetailItemAlias[]
  versions    NutritionRetailItemVersion[]

  @@index([chainId, name])
  @@index([chainId, normalizedName])
  @@index([lastIngestionRunId])
  @@index([lastArtifactId])
}

model NutritionRetailUserItem {
  id          String               @id @default(uuid())
  chainId     String
  chain       NutritionRetailChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  category    String?
  nutrients   Json
  servingSize Float?
  servingUnit String?
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([chainId, userId])
  @@index([userId])
}

model NutritionRetailChainSource {
  id               String                     @id @default(uuid())
  chainId          String
  chain            NutritionRetailChain       @relation(fields: [chainId], references: [id], onDelete: Cascade)
  sourceName       String
  sourceUrl        String?
  manualStoragePath String?
  manualFileName   String?
  manualMimeType   String?
  manualFileSizeBytes Int?
  manualChecksumSha256 String?
  manualUploadedAt DateTime?
  sourceType       NutritionSourceType
  fetchMethod      NutritionFetchMethod       @default(direct_download)
  parserPreference NutritionParserPreference  @default(deterministic_first)
  active           Boolean                    @default(true)
  priority         Int                        @default(0)
  lastVerifiedAt   DateTime?
  notes            String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  runs NutritionRetailIngestionRun[]

  @@index([chainId, active, priority])
  @@unique([chainId, sourceName])
}

model NutritionRetailIngestionRun {
  id                      String                     @id @default(uuid())
  chainId                 String
  chain                   NutritionRetailChain       @relation(fields: [chainId], references: [id], onDelete: Cascade)
  sourceId                String?
  source                  NutritionRetailChainSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  status                  NutritionIngestionRunStatus @default(queued)
  triggeredByUserId       String?
  sourceUrlSnapshot       String?
  sourceTypeSnapshot      NutritionSourceType?
  fetchMethodSnapshot     NutritionFetchMethod?
  parserPreferenceSnapshot NutritionParserPreference?
  errorMessage            String?
  startedAt               DateTime                   @default(now())
  finishedAt              DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  artifacts      NutritionRetailIngestionArtifact[]
  stagingItems   NutritionRetailStagingItem[]
  itemVersions   NutritionRetailItemVersion[]
  producedItems  NutritionRetailItem[]

  @@index([chainId, status])
  @@index([sourceId])
  @@index([startedAt])
}

model NutritionRetailIngestionArtifact {
  id               String                    @id @default(uuid())
  runId            String
  run              NutritionRetailIngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceUrl        String?
  sourceType       NutritionSourceType
  fileName         String?
  mimeType         String?
  storagePath      String?
  fileSizeBytes    Int?
  checksumSha256   String?
  httpStatus       Int?
  parsedResultJson Json?
  fetchedAt        DateTime                  @default(now())
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  stagingItems     NutritionRetailStagingItem[]
  producedItems    NutritionRetailItem[]
  itemVersions     NutritionRetailItemVersion[]

  @@index([runId, fetchedAt])
  @@index([checksumSha256])
}

model NutritionRetailStagingItem {
  id              String                    @id @default(uuid())
  runId           String
  run             NutritionRetailIngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  artifactId      String?
  artifact        NutritionRetailIngestionArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  chainId         String
  chain           NutritionRetailChain      @relation(fields: [chainId], references: [id], onDelete: Cascade)
  name            String
  normalizedName  String
  category        String?
  nutrients       Json
  servingSize     Float?
  servingUnit     String?
  extractionMethod NutritionExtractionMethod
  confidence      Float?
  hardIssueCount  Int                       @default(0)
  softIssueCount  Int                       @default(0)
  reviewed        Boolean                   @default(false)
  approved        Boolean                   @default(false)
  reviewedByUserId String?
  reviewedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  issues NutritionRetailStagingIssue[]

  @@index([runId, approved])
  @@index([artifactId])
  @@index([chainId, normalizedName])
}

model NutritionRetailStagingIssue {
  id            String                    @id @default(uuid())
  stagingItemId String
  stagingItem   NutritionRetailStagingItem @relation(fields: [stagingItemId], references: [id], onDelete: Cascade)
  severity      NutritionValidationSeverity
  code          String
  message       String
  meta          Json?
  createdAt     DateTime                  @default(now())

  @@index([stagingItemId, severity])
  @@index([code])
}

model NutritionRetailItemVersion {
  id            String                     @id @default(uuid())
  retailItemId  String?
  retailItem    NutritionRetailItem?       @relation(fields: [retailItemId], references: [id], onDelete: SetNull)
  runId         String
  run           NutritionRetailIngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  artifactId    String?
  artifact      NutritionRetailIngestionArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  chainId       String
  chain         NutritionRetailChain       @relation(fields: [chainId], references: [id], onDelete: Cascade)
  itemName      String
  normalizedName String
  category      String?
  nutrients     Json
  servingSize   Float?
  servingUnit   String?
  sourceType    NutritionSourceType?
  sourceUrl     String?
  versionNumber Int
  isPublished   Boolean                    @default(true)
  publishedAt   DateTime                   @default(now())
  createdAt     DateTime                   @default(now())

  @@index([runId, publishedAt])
  @@index([retailItemId, versionNumber])
  @@index([chainId, normalizedName])
  @@unique([retailItemId, versionNumber])
}

model NutritionRetailItemAlias {
  id              String                @id @default(uuid())
  chainId         String
  chain           NutritionRetailChain  @relation(fields: [chainId], references: [id], onDelete: Cascade)
  retailItemId    String
  retailItem      NutritionRetailItem   @relation(fields: [retailItemId], references: [id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([chainId, normalizedAlias])
  @@index([retailItemId])
  @@index([chainId, active])
}

model NutritionMealSession {
  id        String   @id @default(uuid())
  userId    String
  loggedAt  DateTime
  dateStr   String
  mealLabel String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NutritionMealItem[]

  @@index([userId, dateStr])
  @@index([userId, loggedAt])
}

model NutritionMealItem {
  id                String              @id @default(uuid())
  sessionId         String
  session           NutritionMealSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  foodSource        NutritionFoodSource
  sourceFoodId      String?
  foundationFoodId  String?
  snapshotName      String
  snapshotBrand     String?
  servings          Float
  portionLabel      String?
  portionGramWeight Float?
  sortOrder         Int                 @default(0)

  snapshotCalories Float
  snapshotProtein  Float
  snapshotCarbs    Float
  snapshotFat      Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nutrients NutritionMealItemNutrient[]

  @@index([sessionId, sortOrder])
}

model NutritionMealItemNutrient {
  id           String            @id @default(uuid())
  mealItemId   String
  mealItem     NutritionMealItem @relation(fields: [mealItemId], references: [id], onDelete: Cascade)
  nutrientKey  String
  nutrientName String
  amount       Float
  unit         String
  createdAt    DateTime          @default(now())

  @@index([mealItemId])
  @@index([nutrientKey, amount])
}

model NutritionFoodPreset {
  id        String   @id @default(uuid())
  userId    String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NutritionFoodPresetItem[]

  @@index([userId, active])
  @@index([userId, name])
}

model NutritionFoodPresetItem {
  id                String              @id @default(uuid())
  presetId          String
  preset            NutritionFoodPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  foodSource        NutritionFoodSource
  sourceFoodId      String?
  foundationFoodId  String?
  snapshotName      String
  snapshotBrand     String?
  servings          Float
  portionLabel      String?
  portionGramWeight Float?
  nutrients         Json
  sortOrder         Int                 @default(0)

  createdAt DateTime @default(now())

  @@index([presetId, sortOrder])
}

model NutritionUserGoals {
  id              String   @id @default(uuid())
  userId          String   @unique
  calories        Float?
  protein         Float?
  carbs           Float?
  fat             Float?
  microGoals      Json?
  waterGoalOz     Float?
  sodiumGoalMg    Float?
  potassiumGoalMg Float?
  magnesiumGoalMg Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum FeedbackStatus {
  NEW
  DEFERRED
  PRIORITY
  NEED_CLARIFICATION
  IGNORED
  COMPLETE
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  message   String
  status    FeedbackStatus @default(NEW)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

model EmailBroadcast {
  id        String    @id @default(cuid())
  subject   String
  body      String
  sentAt    DateTime?
  sentCount Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}

// ─── Knowledge Base ─────────────────────────────────────────────────────────

enum KnowledgeSourceType {
  PODCAST
  PAPER
  MANUAL
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum KnowledgeIngestionStep {
  FETCH
  CHUNK
  EMBED
  EXTRACT_ENTITIES
  RESOLVE_ENTITIES
  SYNTHESIZE_RELATIONSHIPS
  EXTRACT_CLAIMS
  VERIFY_CLAIMS
}

enum KnowledgeIngestionRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum KnowledgeClaimVerification {
  UNVERIFIED
  SUPPORTED
  CONTESTED
  REFUTED
}

model KnowledgeChannel {
  id                 String    @id @default(uuid())
  channelId          String    @unique
  name               String
  url                String
  topicDomains       String[]
  relevanceThreshold Float     @default(0.7)
  active             Boolean   @default(true)
  lastScannedAt      DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sources KnowledgeSource[]

  @@index([active])
}

model KnowledgeSource {
  id             String                @id @default(uuid())
  sourceType     KnowledgeSourceType
  title          String
  authors        String[]
  publishedAt    DateTime?
  externalId     String?
  url            String?
  channelId      String?
  channel        KnowledgeChannel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  status         KnowledgeSourceStatus @default(PENDING)
  relevanceScore Float?
  fetchTier      String?
  metadata       Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  ingestionRuns KnowledgeIngestionRun[]
  claims        KnowledgeClaim[]

  @@unique([sourceType, externalId])
  @@index([status])
  @@index([channelId])
  @@index([sourceType])
}

model KnowledgeIngestionRun {
  id          String                      @id @default(uuid())
  sourceId    String
  source      KnowledgeSource             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  step        KnowledgeIngestionStep
  status      KnowledgeIngestionRunStatus @default(PENDING)
  error       String?
  stats       Json?
  batchId     String?
  startedAt   DateTime                    @default(now())
  completedAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([sourceId, step])
  @@index([status])
  @@index([batchId])
}

model KnowledgeClaim {
  id                 String                       @id @default(uuid())
  sourceId           String
  source             KnowledgeSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunkRef           String?
  claimText          String
  confidence         Float?
  verificationStatus KnowledgeClaimVerification   @default(UNVERIFIED)
  supportingPaperIds String[]
  metadata           Json?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([sourceId])
  @@index([verificationStatus])
}
